2. **External Service Integration**:
   - HTTP adapters for third-party APIs (Payment, Trading)
   - Strategy Pattern to switch providers easily

```typescript
// src/infrastructure/adapters/pay2pay.adapter.ts
@Injectable()
export class Pay2PayAdapter implements PaymentApiPort {
  private client: AxiosInstance;

  type Pay2PayOrderResponse = Omit<
    PaymentOrder,
    'amount' | 'cryptoAmount' | 'createdAt' | 'updatedAt'
  > & {
    amount: string;
    cryptoAmount?: string | null;
    createdAt: string;
    updatedAt: string;
  };

  constructor(private readonly configService: ConfigService<AllConfigType>) {
    const apiKey = this.configService.get('payment.pay2pay.apiKey', {
      infer: true,
    });
    const apiUrl = this.configService.get('payment.pay2pay.apiUrl', {
      infer: true,
    });

    this.client = axios.create({
      baseURL: apiUrl,
      headers: {
        Authorization: `Bearer ${apiKey}`,
        'Content-Type': 'application/json',
      },
    });
  }

  async createPayinOrder(data: CreatePayinOrderDto): Promise<PaymentOrder> {
    const response = await this.client.post<Pay2PayOrderResponse>('/api/v1/payin', {
      amount: data.amount,
      currency: data.currency,
      cryptoCurrency: data.cryptoCurrency,
      userId: data.userId,
      callbackUrl: data.callbackUrl,
    });
    return this.mapToPaymentOrder(response.data);
  }

  async getOrderDetails(orderId: string): Promise<PaymentOrder> {
    const response = await this.client.get<Pay2PayOrderResponse>(`/api/v1/orders/${orderId}`);
    return this.mapToPaymentOrder(response.data);
  }

  private mapToPaymentOrder(data: Pay2PayOrderResponse): PaymentOrder {
    const parseNumber = (value: string): number => {
      const parsed = Number.parseFloat(value);
      if (!Number.isFinite(parsed)) {
        throw new Error('Invalid number');
      }
      return parsed;
    };

    return {
      id: data.id,
      userId: data.userId,
      amount: parseNumber(data.amount),
      currency: data.currency,
      cryptoAmount: data.cryptoAmount ? parseNumber(data.cryptoAmount) : null,
      cryptoCurrency: data.cryptoCurrency,
      status: data.status,
      createdAt: new Date(data.createdAt),
      updatedAt: new Date(data.updatedAt),
    };
  }
}

// src/application/payment/strategies/pay2pay-payment.strategy.ts
@Injectable()
export class Pay2PayPaymentStrategy implements IPaymentStrategy {
  readonly name = 'pay2pay';

  constructor(
    @Inject(PAYMENT_API_PORT)
    private readonly paymentAdapter: PaymentApiPort,
    @Inject(PAYMENT_ORDER_REPOSITORY_PORT)
    private readonly orderRepository: PaymentOrderRepositoryPort,
  ) {}

  async createPayinOrder(data: CreatePayinOrderDto): Promise<PaymentOrder> {
    // Create order via Pay2Pay API
    const order = await this.paymentAdapter.createPayinOrder(data);

    // Store in database
    await this.orderRepository.create({
      externalOrderId: order.id,
      userId: data.userId,
      provider: 'pay2pay',
      amount: data.amount,
      currency: data.currency,
      status: order.status,
    });

    return order;
  }

  async getOrderDetails(orderId: string): Promise<PaymentOrder> {
    return await this.paymentAdapter.getOrderDetails(orderId);
  }
}
```

3. **Dependency Injection with Symbols**:
   - Use Symbol tokens for interface-based injection
   - Supports hexagonal architecture (ports/adapters)

```typescript
// src/application/authorization/ports/tokens.ts
export const ROLE_REPOSITORY_PORT = Symbol('RoleRepositoryPort');
export const PERMISSION_REPOSITORY_PORT = Symbol('PermissionRepositoryPort');

// src/application/identity/ports/tokens.ts
export const USER_REPOSITORY_PORT = Symbol('UserRepositoryPort');
export const PASSWORD_HASHER_PORT = Symbol('PasswordHasherPort');
export const TOKEN_PORT = Symbol('TokenPort');

// Module registration
@Module({
  imports: [TypeOrmModule.forFeature([UserEntity])],
  providers: [
    // Adapter implementation
    {
      provide: USER_REPOSITORY_PORT,
      useClass: UserRepositoryAdapter,
    },
    {
      provide: PASSWORD_HASHER_PORT,
      useClass: BcryptPasswordHasher,
    },
    {
      provide: TOKEN_PORT,
      useClass: JwtTokenProvider,
    },
    // Strategies
    EmailPasswordAuthStrategy,
    GoogleOAuthStrategy,
    AppleOAuthStrategy,
    PasskeyAuthStrategy,
    // Factory
    AuthStrategyFactory,
    // Handlers
    LoginCommandHandler,
  ],
  exports: [
    USER_REPOSITORY_PORT,
    PASSWORD_HASHER_PORT,
    TOKEN_PORT,
    AuthStrategyFactory,
  ],
})
export class IdentityModule {}

// Usage in handler
@CommandHandler(LoginCommand)
export class LoginCommandHandler implements ICommandHandler<LoginCommand> {
  constructor(
    @Inject(USER_REPOSITORY_PORT)
    private readonly userRepository: UserRepositoryPort,
    private readonly authStrategyFactory: AuthStrategyFactory,
  ) {}

  async execute(command: LoginCommand): Promise<AuthResult> {
    const strategy = this.authStrategyFactory.getStrategy(
      command.credentials.type,
    );
    return await strategy.authenticate(command.credentials);
  }
}
```

## Key Flows

1. **User Authentication with Strategy Pattern**:

   ```
   LoginDTO → Controller → LoginCommand → CommandHandler → AuthStrategyFactory
   → Strategy.authenticate() → Repository → TokenProvider → AuthResult
   ```

2. **Trading Order Placement**:

   ```
   PlaceOrderDTO → Controller → PlaceOrderCommand → CommandHandler
   → TradingStrategyFactory → Strategy.placeOrder() → BrokerAdapter → External API
   ```

3. **Payment Processing with Provider Switch**:

   ```
   CreatePayinDTO → Controller → CreatePayinCommand → CommandHandler
   → PaymentStrategyFactory → Pay2PayStrategy (switched from Transfi)
   → Pay2PayAdapter → External API → Store in DB
   ```

4. **Query Flow with CQRS**:

```typescript
// src/application/authorization/queries/get-roles/get-roles.query.ts
export class GetRolesQuery implements IQuery {
  constructor(public readonly filters?: RoleFilters) {}
}

// src/application/authorization/queries/get-roles/get-roles.handler.ts
@QueryHandler(GetRolesQuery)
export class GetRolesHandler implements IQueryHandler<GetRolesQuery> {
  constructor(
    @Inject(ROLE_REPOSITORY_PORT)
    private readonly roleRepository: RoleRepositoryPort,
  ) {}

  async execute(query: GetRolesQuery): Promise<Role[]> {
    return await this.roleRepository.findAll(query.filters);
  }
}

// src/presentation/http/controllers/roles.controller.ts
@Controller('roles')
export class RolesController {
  constructor(private readonly queryBus: QueryBus) {}

  @Get()
  @HttpCode(HttpStatus.OK)
  async getRoles(@Query() filters: RoleFilters): Promise<Role[]> {
    return await this.queryBus.execute(new GetRolesQuery(filters));
  }
}
```

## Getting Started Tips

1. **Start with Domain Layer**: Define entities, value objects, and domain rules first
2. **Define Ports in Application Layer**: Create interfaces (ports) for external dependencies
3. **Implement Adapters in Infrastructure**: Implement ports with concrete adapters
4. **Use CQRS Pattern**: Separate commands (write) and queries (read) operations
5. **Apply Strategy Pattern Only When Needed**: Use when you have multiple implementations (auth providers, brokers, payment gateways)
6. **Use Symbol Tokens for DI**: Enable proper hexagonal architecture with interface-based injection
7. **Separate Domain and Persistence**: Use mappers to convert between domain entities and TypeORM entities
8. **Follow Naming Conventions**: Use kebab-case for folders, PascalCase for classes, camelCase for variables

## Important Dependencies

### Core Framework

- **@nestjs/core**: Main NestJS framework
- **@nestjs/common**: Common decorators and utilities
- **@nestjs/cqrs**: CQRS pattern implementation (CommandBus, QueryBus, EventBus)

### Database & ORM

- **@nestjs/typeorm**: TypeORM integration for NestJS
- **typeorm**: ORM for database operations
- **pg**: PostgreSQL driver

### Authentication & Security

- **@nestjs/jwt**: JWT token generation and validation
- **@nestjs/passport**: Authentication middleware
- **bcryptjs**: Password hashing
- **@simplewebauthn/server**: WebAuthn/Passkey implementation

### External Services

- **axios**: HTTP client for external API calls
- **@alpacahq/alpaca-trade-api**: Alpaca trading integration

### Validation

- **class-validator**: DTO validation decorators
- **class-transformer**: DTO transformation

### Utilities

- **uuid**: UUID generation (use uuidv7 for better performance)
- **date-fns**: Date manipulation

This structure provides a maintainable foundation for a fintech platform with authentication, trading, and payment capabilities using Clean Architecture and Domain-Driven Design principles.
