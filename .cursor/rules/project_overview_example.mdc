5. **Strategy Pattern** (when needed for multiple implementations):
   - Used for authentication providers, payment providers, trading brokers

```typescript
// src/domain/strategies/auth/i-auth-strategy.ts
export interface IAuthStrategy {
  readonly name: string;
  authenticate(credentials: AuthCredentials): Promise<AuthResult>;
  validate(token: string): Promise<User>;
}

// src/application/identity/strategies/email-password-auth.strategy.ts
@Injectable()
export class EmailPasswordAuthStrategy implements IAuthStrategy {
  readonly name = 'email-password';

  constructor(
    @Inject(USER_REPOSITORY_PORT)
    private readonly userRepository: UserRepositoryPort,
    @Inject(PASSWORD_HASHER_PORT)
    private readonly passwordHasher: PasswordHasherPort,
    @Inject(TOKEN_PORT)
    private readonly tokenProvider: TokenPort,
  ) {}

  async authenticate(credentials: AuthCredentials): Promise<AuthResult> {
    if (credentials.type !== 'email-password') {
      throw new InvalidCredentialsError('Invalid credentials type');
    }

    const user = await this.userRepository.findByEmail(credentials.email);
    if (!user) {
      throw new InvalidCredentialsError('Invalid email or password');
    }

    const isValid = await this.passwordHasher.compare(
      credentials.password,
      user.password,
    );
    if (!isValid) {
      throw new InvalidCredentialsError('Invalid email or password');
    }

    const accessToken = await this.tokenProvider.generateAccessToken(user);
    const refreshToken = await this.tokenProvider.generateRefreshToken(user);

    return { user, accessToken, refreshToken, expiresIn: 3600 };
  }

  async validate(token: string): Promise<User> {
    return this.tokenProvider.verifyAccessToken(token);
  }
}

// src/application/identity/factories/auth-strategy.factory.ts
@Injectable()
export class AuthStrategyFactory {
  private strategies: Map<string, IAuthStrategy>;

  constructor(
    private readonly emailPasswordStrategy: EmailPasswordAuthStrategy,
    private readonly googleOAuthStrategy: GoogleOAuthStrategy,
    private readonly appleOAuthStrategy: AppleOAuthStrategy,
    private readonly passkeyStrategy: PasskeyAuthStrategy,
  ) {
    this.strategies = new Map([
      ['email-password', emailPasswordStrategy],
      ['google-oauth', googleOAuthStrategy],
      ['apple-oauth', appleOAuthStrategy],
      ['passkey', passkeyStrategy],
    ]);
  }

  getStrategy(type: string): IAuthStrategy {
    const strategy = this.strategies.get(type);
    if (!strategy) {
      throw new Error(`Authentication strategy '${type}' not found`);
    }
    return strategy;
  }
}
```

## Core Domain Models

1. **Identity & Authorization**:
   - `User` aggregate root with role-based access control
   - `Role` entity with permissions collection
   - `Permission` entity for fine-grained access

```typescript
// src/domain/entities/user.ts
export class User extends BaseEntity {
  private constructor(
    public readonly id: string,
    public email: string,
    public firstName: string | null,
    public lastName: string | null,
    public password: string | null,
    public role: Role,
    public provider: AuthProvidersEnum,
    public socialId: string | null,
    public status: Status,
  ) {
    super();
  }

  static create(props: CreateUserProps): User {
    if (!props.email) {
      throw new DomainException('Email cannot be empty');
    }

    return new User(
      generateUuidV7(),
      props.email,
      props.firstName,
      props.lastName,
      props.password,
      props.role,
      props.provider,
      props.socialId,
      Status.ACTIVE,
    );
  }

  update(props: UpdateUserProps): void {
    if (props.firstName !== undefined) {
      this.firstName = props.firstName;
    }
    if (props.lastName !== undefined) {
      this.lastName = props.lastName;
    }
    this.markAsUpdated();
  }

  isActive(): boolean {
    return this.status === Status.ACTIVE && !this.isDeleted();
  }

  deactivate(): void {
    this.status = Status.INACTIVE;
    this.markAsUpdated();
  }
}

// src/domain/entities/role.ts
export class Role extends BaseEntity {
  private permissions: Permission[] = [];

  private constructor(
    public readonly id: string,
    public name: string,
  ) {
    super();
  }

  static create(props: CreateRoleProps): Role {
    if (!props.name) {
      throw new DomainException('Role name cannot be empty');
    }

    const role = new Role(generateUuidV7(), props.name);
    if (props.permissions) {
      role.permissions = props.permissions;
    }
    return role;
  }

  getPermissions(): readonly Permission[] {
    return this.permissions;
  }

  addPermission(permission: Permission): void {
    if (!this.hasPermission(permission.id)) {
      this.permissions.push(permission);
      this.markAsUpdated();
    }
  }

  removePermission(permissionId: string): void {
    this.permissions = this.permissions.filter((p) => p.id !== permissionId);
    this.markAsUpdated();
  }

  hasPermission(permissionId: string): boolean {
    return this.permissions.some((p) => p.id === permissionId);
  }
}
```

