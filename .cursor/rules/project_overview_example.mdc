3. **Auditing**:
   - Base entity class tracks creation/modification/deletion dates

```typescript
// src/domain/common/base-entity.ts
export abstract class BaseEntity {
  id: string;
  createdAt: Date;
  updatedAt: Date;
  deletedAt: Date | null;

  constructor() {
    this.createdAt = new Date();
    this.updatedAt = new Date();
    this.deletedAt = null;
  }

  markAsUpdated(): void {
    this.updatedAt = new Date();
  }

  markAsDeleted(): void {
    this.deletedAt = new Date();
  }

  isDeleted(): boolean {
    return this.deletedAt !== null;
  }
}
```

4. **Hexagonal Architecture (Ports & Adapters)**:
   - Ports define contracts in application layer
   - Adapters implement ports in infrastructure layer

```typescript
// src/application/authorization/ports/role-repository.port.ts
export interface RoleRepositoryPort {
  create(data: CreateRoleData): Promise<Role>;
  findById(id: string): Promise<NullableType<Role>>;
  findByName(name: string): Promise<NullableType<Role>>;
  update(id: string, data: Partial<Role>): Promise<void>;
  delete(id: string): Promise<void>;
}

// src/application/authorization/ports/tokens.ts
export const ROLE_REPOSITORY_PORT = Symbol('RoleRepositoryPort');

// src/infrastructure/repositories/role-repository.adapter.ts
@Injectable()
export class RoleRepositoryAdapter implements RoleRepositoryPort {
  constructor(
    @InjectRepository(RoleEntity)
    private readonly repository: Repository<RoleEntity>,
  ) {}

  async create(data: CreateRoleData): Promise<Role> {
    const entity = this.repository.create(data);
    const saved = await this.repository.save(entity);
    return RoleMapper.toDomain(saved);
  }

  async findById(id: string): Promise<NullableType<Role>> {
    const entity = await this.repository.findOne({ where: { id } });
    return entity ? RoleMapper.toDomain(entity) : null;
  }

  async findByName(name: string): Promise<NullableType<Role>> {
    const entity = await this.repository.findOne({ where: { name } });
    return entity ? RoleMapper.toDomain(entity) : null;
  }
}
