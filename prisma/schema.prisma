// Prisma 7 schema for nest-clean-arch-boilerplate
// Hand-authored from TypeORM entities (commit 51b195d~1) — verify with `prisma db pull` once DB is up.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PermissionAction {
  manage
  create
  read
  update
  delete
}

enum PermissionSubject {
  user
  permission
  role
  all
}

model User {
  id           String    @id @db.Uuid
  email        String?   @unique
  password     String?
  state        String    @default("active")
  provider     String    @default("email")
  socialId     String?   @map("social_id")
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  verifiedAt   DateTime? @map("verified_at") @db.Timestamptz
  firstLoginAt DateTime? @map("first_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  roles       UserRole[]
  sessions    Session[]
  credentials WebAuthnCredential[]

  @@index([socialId])
  @@index([firstName])
  @@index([lastName])
  @@map("users")
}

model Role {
  id        String    @id @db.Uuid
  name      String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id         String            @id @db.Uuid
  name       String            @unique
  action     PermissionAction
  subject    PermissionSubject
  conditions Json?
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime?         @map("deleted_at") @db.Timestamptz

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  hash      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model WebAuthnCredential {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  credentialId String    @unique @map("credential_id")
  publicKey    String    @map("public_key")
  counter      BigInt    @default(0)
  transports   Json?
  backedUp     Boolean   @default(false) @map("backed_up")
  deviceType   String?   @map("device_type") @db.VarChar(50)
  aaguid       String?   @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("webauthn_credentials")
}
