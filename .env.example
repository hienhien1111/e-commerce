# Database Configuration
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=app
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

# Prisma 7 uses DATABASE_URL exclusively (configured in Phase 3 migration)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/app?schema=public

# Application Configuration
NODE_ENV=development
APP_PORT=3002
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3002
BACKEND_DOMAIN=http://localhost:3002

# CORS: comma-separated list of allowed origins, or '*' / empty for allow-all (dev only)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Rate limiting (global default; override per-route with @Throttle decorator)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# JWT Authentication Configuration
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_TOKEN_EXPIRES_IN=30d
AUTH_FORGOT_SECRET=your-forgot-secret-change-this-in-production-min-32-chars
AUTH_FORGOT_TOKEN_EXPIRES_IN=1h
AUTH_CONFIRM_EMAIL_SECRET=your-confirm-email-secret-change-this-in-production-min-32-chars
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# Required: RSA key pairs (PEM content with \n for newlines). RS256 is enforced.
ACCESS_JWT_PRIVATE_KEY=
ACCESS_JWT_PUBLIC_KEY=

# Refresh token key pair
REFRESH_JWT_PRIVATE_KEY=
REFRESH_JWT_PUBLIC_KEY=

# WebAuthn Configuration
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=
WEBAUTHN_ALLOWED_ORIGINS=
WEBAUTHN_CHALLENGE_TTL_SEC=

# SSL Configuration (if needed)
# DATABASE_CA=
# DATABASE_KEY=
# DATABASE_CERT=

# OpenTelemetry (optional; SDK is a no-op unless one of these is set)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=nest-clean-arch-boilerplate

# Redis (optional). When set, WebAuthn challenge store uses Redis for
# multi-instance scalability. When unset, falls back to in-process Map.
# REDIS_URL=redis://localhost:6379
