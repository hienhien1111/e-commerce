# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/shop?schema=public

# Application Configuration
NODE_ENV=development
APP_PORT=3002
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:3002

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# JWT Authentication Configuration
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_TOKEN_EXPIRES_IN=30d
AUTH_FORGOT_SECRET=your-forgot-secret-change-this-in-production-min-32-chars
AUTH_FORGOT_TOKEN_EXPIRES_IN=1h
AUTH_CONFIRM_EMAIL_SECRET=your-confirm-email-secret-change-this-in-production-min-32-chars
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# Transactional email (Resend)
# onboarding@resend.dev is for development/testing only. Production requires
# RESEND_FROM from a verified Resend domain.
RESEND_API_KEY=
RESEND_FROM=Shop <onboarding@resend.dev>

# Production manual admin bootstrap only; never committed as a real secret.
# bun run admin:create -- --email "$ADMIN_EMAIL" --password "$ADMIN_PASSWORD"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Required: RSA key pairs (PEM content with \n for newlines). RS256 is enforced.
ACCESS_JWT_PRIVATE_KEY=
ACCESS_JWT_PUBLIC_KEY=

# Refresh token key pair
REFRESH_JWT_PRIVATE_KEY=
REFRESH_JWT_PUBLIC_KEY=

# WebAuthn Configuration
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=ShopApp
WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3002
WEBAUTHN_CHALLENGE_TTL_SEC=300

# ============================================================
# Google OAuth
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local development callback (ngrok is optional and only needed for public HTTPS callbacks)
GOOGLE_CALLBACK_URL=http://localhost:3002/api/v1/google/callback

# ============================================================
# Cloudinary (avatar + product images)
# ============================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================
# MoMo Payment (Sandbox)
# Docs: https://developers.momo.vn/#/docs/en/aiov2/?id=payment-method
# ============================================================
MOMO_PARTNER_CODE=MOMO_ATM_DEV
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn
# After running: make ngrok-url — paste the ngrok URL here
MOMO_IPN_URL=https://<ngrok-id>.ngrok-free.app/api/v1/webhooks/momo
MOMO_REDIRECT_URL=http://localhost:3000/checkout/success

# ============================================================
# Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# ============================================================
# ngrok (optional — for Google OAuth + MoMo IPN tunneling)
# Get free token at https://dashboard.ngrok.com
# ============================================================
NGROK_AUTHTOKEN=

# ============================================================
# OpenTelemetry (optional)
# ============================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=shop-api

# ============================================================
# Redis (optional — for WebAuthn challenge store in multi-instance)
# ============================================================
# REDIS_URL=redis://localhost:6379
