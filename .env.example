# Database Configuration
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=uob_portal
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
# Optional: Use DATABASE_URL instead of individual connection parameters
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uob_portal

# Application Configuration
NODE_ENV=development
APP_PORT=3002
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3002
BACKEND_DOMAIN=http://localhost:3002

# JWT Authentication Configuration
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_TOKEN_EXPIRES_IN=30d
AUTH_FORGOT_SECRET=your-forgot-secret-change-this-in-production-min-32-chars
AUTH_FORGOT_TOKEN_EXPIRES_IN=1h
AUTH_CONFIRM_EMAIL_SECRET=your-confirm-email-secret-change-this-in-production-min-32-chars
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# Required: RSA key pairs (PEM content with \n for newlines). RS256 is enforced.
ACCESS_JWT_PRIVATE_KEY=
ACCESS_JWT_PUBLIC_KEY=

# Refresh token key pair
REFRESH_JWT_PRIVATE_KEY=
REFRESH_JWT_PUBLIC_KEY=


# WebAuthn Configuration
#WEBAUTHN_RP_ID=
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=
WEBAUTHN_ALLOWED_ORIGINS=
WEBAUTHN_CHALLENGE_TTL_SEC=

# SSL Configuration (if needed)
# DATABASE_CA=
# DATABASE_KEY=
# DATABASE_CERT=

# TransFi credentials
TRANSFI_API_USERNAME=your_username
TRANSFI_API_PASSWORD=your_merchant_key
TRANSFI_MID=your_merchant_id
# Môi trường sandbox / production
TRANSFI_API_BASE_URL=

# Webhook secret (nếu dùng webhook)
TRANSFI_WEBHOOK_SECRET=your_webhook_secret

# Optional: invoice / purpose code
TRANSFI_DEFAULT_PURPOSE_CODE=investment
TRANSFI_DEFAULT_PURPOSE_CODE_REASON=stock_deposit


ALPACA_CLIENT_ID=your_client_id
ALPACA_CLIENT_SECRET=your_client_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_IS_PAPER=true
ALPACA_REDIRECT_URI=http://localhost:3002/alpaca/auth/callback

# Alpaca WebSocket API Credentials (for backend streaming)
ALPACA_WS_API_KEY=your_ws_api_key
ALPACA_WS_API_SECRET=your_ws_api_secret