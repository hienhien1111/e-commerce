{
  "name": "nest-clean-arch-boilerplate",
  "version": "1.2.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "typeorm": "env-cmd ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "bash scripts/migration-generate.sh",
    "postmigration:generate": "bun run lint -- --fix",
    "migration:create": "bun run typeorm -- migration:create",
    "migration:run": "bun run typeorm -- --dataSource=src/database/data-source.ts migration:run",
    "migration:revert": "bun run typeorm -- --dataSource=src/database/data-source.ts migration:revert",
    "seed:run": "env-cmd ts-node -r tsconfig-paths/register src/database/seeds/run-seed.ts",
    "schema:drop": "bun run typeorm -- --dataSource=src/database/data-source.ts schema:drop",
    "generate:module": "hygen module new",
    "app:config": "ts-node -r tsconfig-paths/register ./.install-scripts/index.ts && bun install && bun run lint -- --fix",
    "prebuild": "rimraf dist",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "env-cmd jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:docker": "docker compose -f docker-compose.e2e.yaml up -d --wait && bun run test:e2e; docker compose -f docker-compose.e2e.yaml down",
    "test:e2e:up": "docker compose -f docker-compose.e2e.yaml up -d --wait",
    "test:e2e:down": "docker compose -f docker-compose.e2e.yaml down -v",
    "prepare": "is-ci || husky"
  },
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "11.1.3",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.3",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.3",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/swagger": "11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "11.0.0",
    "@nestjs/websockets": "^11.1.9",
    "@simplewebauthn/server": "^13.2.2",
    "@simplewebauthn/types": "^12.0.0",
    "bcryptjs": "3.0.2",
    "class-transformer": "0.5.1",
    "class-validator": "^0.14.2",
    "ms": "2.1.3",
    "nestjs-i18n": "10.5.1",
    "passport": "0.7.0",
    "passport-anonymous": "1.0.1",
    "passport-custom": "^1.1.1",
    "passport-jwt": "4.0.1",
    "passport-local": "^1.0.0",
    "pg": "8.16.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "6.0.1",
    "rxjs": "7.8.2",
    "typeorm": "0.3.25",
    "uuid": "^13.0.0",
    "uuidv7": "^1.0.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.20.0",
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "11.0.5",
    "@nestjs/testing": "^11.1.9",
    "@types/bcryptjs": "3.0.0",
    "@types/express": "5.0.3",
    "@types/jest": "30.0.0",
    "@types/ms": "2.1.0",
    "@types/node": "22.15.33",
    "@types/passport-anonymous": "1.0.5",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.34.1",
    "@typescript-eslint/parser": "8.34.1",
    "env-cmd": "10.1.0",
    "eslint": "9.29.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.5.0",
    "globals": "^16.0.0",
    "husky": "9.1.7",
    "hygen": "^6.2.11",
    "is-ci": "4.1.0",
    "jest": "30.0.3",
    "prettier": "3.6.1",
    "ts-jest": "29.4.0",
    "ts-node": "10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "4.2.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "typescript": "5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
